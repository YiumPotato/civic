[Unit]
Description=Civic Coordination Platform
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/civic
ExecStart=/opt/civic/civic-server
Restart=always
RestartSec=5
Environment=PORT=4444
Environment=DB_PATH=/opt/civic/civic.db

[Install]
WantedBy=multi-user.target
